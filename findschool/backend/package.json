{
  "name": "goschool-backend",
  "version": "1.0.0",
  "description": "GoSchool API Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "type-check": "tsc --noEmit",
    "migrate": "node dist/migrations/index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.10.0",
    "pg-promise": "^11.5.0",
    "axios": "^1.5.0",
    "jsonwebtoken": "^9.1.0",
    "bcrypt": "^5.1.1",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.11.2",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.6",
    "typescript": "^5.3.2",
    "ts-node-dev": "^2.0.0",
    "prettier": "^3.1.0",
    "eslint": "^8.55.0"
  }
}
